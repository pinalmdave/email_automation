# Gmail IMAP credentials (use Gmail App Password, not account password)
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_app_password

# Anthropic API Key (or set as system environment variable)
ANTHROPIC_API_KEY=your_key_here

# Claude model (default: claude-opus-4-8)
CLAUDE_MODEL=claude-opus-4-8

# Scan interval in seconds (default: 3600 = 1 hour)
SCAN_INTERVAL_SECONDS=3600

# Max email age in hours (default: 24)
MAX_EMAIL_AGE_HOURS=24

# Folders to scan (comma-separated)
SCAN_FOLDERS=INBOX,UPDATES

# Sender domains to exclude from scanning (comma-separated)
EXCLUDED_DOMAINS=gmail.com,substack.com

# Resume output directory
RESUME_OUTPUT_DIR=C:\Users\Mr.Dave\OneDrive\Desktop\CLAUDE_GENERATED_RESUME
